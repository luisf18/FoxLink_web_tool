{
    "0": {
        "model": "ESC 2x Brushed",
        
        "struct":{

            "motor":{
                "config": {
                    "offset": 0,
                    "wg": {
                        "name": "Config. Flags",
                        "type": "check",
                        "defaultValue": 0,
                        "checkOptions": [
                            "Bidirectional",
                            "Invert",
                            "Set Min. Power",
                            "Set Max. Power" 
                        ],
                        "externalActions": [
                            {
                                "type": "visible",
                                "to": "ch_min",
                                "expr": { "op": "bitClear", "bit": 0 }
                            },
                            {
                                "type": "visible",
                                "to": "min",
                                "expr": { "op": "bitClear", "bit": 2 }
                            },
                            {
                                "type": "visible",
                                "to": "max",
                                "expr": { "op": "bitClear", "bit": 3 }
                            }
                        ]
                    }
                },
                "min": {
                    "offset": 1,
                    "wg": {
                        "unit": "%",
                        "name": "Min. power",
                        "type": "slide",
                        "defaultValue": 0,
                        "abstract": [0, 100],
                        "externalActions": [
                            {
                                "type": "set",
                                "expr": { "value": "real" },
                                "to": { "widget": "max", "property": "real.limitMin" }
                            }
                        ]
                    }
                },
                "max": {
                    "offset": 2,
                    "wg": {
                        "unit": "%",
                        "name": "Max. power",
                        "type": "slide",
                        "defaultValue": 255,
                        "abstract": [0, 100]
                    }
                },
                "ch_min": {
                    "offset": 4,
                    "wg": {
                        "name": "Ch min",
                        "type": "slide",
                        "defaultValueAbs": 1000,
                        "abstract": [860, 2135]
                    }
                },
                "ch_center": {
                    "offset": 3,
                    "wg": {
                        "name": "Ch center",
                        "type": "slide",
                        "defaultValue": 128,
                        "abstract": [860, 2135],
                        "externalActions": [
                            {
                                "type": "set",
                                "expr": "real",
                                "to": { "widget": "ch_min", "property": "real.limitMax" }
                            },
                            {
                                "type": "set",
                                "expr": "real",
                                "to": { "widget": "ch_max", "property": "real.limitMin" }
                            },
                            {
                                "type": "#set",
                                "expr": { "op": "minus", "value": [
                                    "abs",
                                    { "widget": "ch_deadband", "property": "real" }
                                ] },
                                "to": { "widget": "ch_min", "property": "abs.limitMax" }
                            },
                            {
                                "type": "#set",
                                "expr": { "op": "sum", "value": [
                                    "abs",
                                    { "widget": "ch_deadband", "property": "real" }
                                ] },
                                "to": { "widget": "ch_max", "property": "abs.limitMin" }
                            }
                        ]
                    }
                },
                "ch_max": {
                    "offset": 5,
                    "wg": {
                        "name": "Ch max",
                        "type": "slide",
                        "defaultValueAbs": 2000,
                        "abstract": [860, 2135]
                    }
                },
                "ch_deadband": {
                    "offset": 6,
                    "wg": {
                        "name": "Ch deadband",
                        "type": "slide",
                        "defaultValue": 20,
                        "externalActions": [
                            {
                                "type": "#update",
                                "to": "ch_center"
                            }
                        ]
                    }
                }

            }
        },

        "param": {
            "name": {
                "addr": 47,
                "wg": {
                    "name": "Name",
                    "type": "string",
                    "defaultValue": "BESC 2x",
                    "outputLen": 16
                }
            },
            "basic": {
                "addr": "0x03",
                "wg": {
                    "name": "Basic config.",
